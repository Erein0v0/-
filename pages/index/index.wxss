.page { padding:24rpx; padding-bottom:120rpx; background:#f5f5f5; min-height:100vh; }

.header { background:linear-gradient(135deg,#07c160,#06ad56); border-radius:24rpx; padding:40rpx 32rpx; margin-bottom:24rpx; color:#fff; }
.header-date { display:block; font-size:36rpx; font-weight:700; margin-bottom:8rpx; }
.header-sub { font-size:26rpx; opacity:.85; }

.card { background:#fff; border-radius:20rpx; padding:32rpx; margin-bottom:20rpx; box-shadow:0 2rpx 16rpx rgba(0,0,0,.06); }
.field-label { display:flex; justify-content:space-between; align-items:center; font-size:28rpx; font-weight:600; color:#333; margin-bottom:20rpx; }
.hours-badge { background:#e8f8ef; color:#07c160; font-size:26rpx; font-weight:700; padding:6rpx 20rpx; border-radius:30rpx; }

.picker-row { display:flex; justify-content:space-between; align-items:center; background:#f8f8f8; border-radius:12rpx; padding:20rpx 24rpx; }
.picker-val { font-size:30rpx; color:#333; }
.picker-arrow { font-size:36rpx; color:#999; }

.slider-tips { display:flex; justify-content:space-between; font-size:22rpx; color:#bbb; margin-top:8rpx; }

.submit-btn { background:#07c160; border-radius:50rpx; padding:32rpx; text-align:center; color:#fff; font-size:32rpx; font-weight:700; margin-bottom:24rpx; box-shadow:0 6rpx 20rpx rgba(7,193,96,.35); }
.btn-disabled { opacity:.6; }

.record-row { display:flex; align-items:center; padding:16rpx 0; border-bottom:1rpx solid #f5f5f5; }
.record-row:last-child { border-bottom:none; }
.avatar { width:64rpx; height:64rpx; border-radius:50%; background:#e8f8ef; color:#07c160; font-size:28rpx; font-weight:700; display:flex; align-items:center; justify-content:center; margin-right:20rpx; flex-shrink:0; }
.record-info { flex:1; }
.record-name { display:block; font-size:30rpx; color:#333; font-weight:600; }
.record-sub { display:block; font-size:24rpx; color:#999; margin-top:4rpx; }
.record-cost { font-size:28rpx; font-weight:600; }
.cost-ok { color:#07c160; }
.cost-pending { color:#bbb; }

.empty-tip { text-align:center; color:#bbb; font-size:26rpx; padding:60rpx 0; }

/* ── 区间统计 ── */
.range-card { }
.range-row { display:flex; align-items:center; gap:12rpx; margin-bottom:20rpx; }
.range-item { flex:1; }
.range-label { display:block; font-size:24rpx; color:#999; margin-bottom:8rpx; }
.range-picker { background:#f8f8f8; border-radius:12rpx; padding:18rpx 20rpx;
  font-size:28rpx; color:#bbb; text-align:center; }
.range-picker.filled { color:#333; }
.range-sep { font-size:32rpx; color:#ccc; flex-shrink:0; margin-top:24rpx; }

.range-result { margin-top:16rpx; }
.range-date-range { font-size:24rpx; color:#999; margin-bottom:12rpx; display:block; }
.range-kpi-row { display:flex; align-items:center; background:#f8fdf9;
  border-radius:16rpx; padding:24rpx 16rpx; margin-bottom:16rpx; }
.range-kpi { flex:1; text-align:center; }
.range-kpi-val { display:block; font-size:36rpx; font-weight:700; color:#333; }
.range-kpi-val.green { color:#07c160; }
.range-kpi-label { display:block; font-size:22rpx; color:#999; margin-top:6rpx; }
.range-kpi-divider { width:1rpx; height:60rpx; background:#e0f0e8; flex-shrink:0; }
.range-divider { height:1rpx; background:#f0f0f0; margin:12rpx 0; }
