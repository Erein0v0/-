.page { padding:24rpx; background:#f5f5f5; min-height:100vh; padding-bottom:120rpx; }

/* 月份导航 */
.month-nav { display:flex; justify-content:space-between; align-items:center;
  background:linear-gradient(135deg,#07c160,#06ad56); border-radius:20rpx;
  padding:20rpx 24rpx; margin-bottom:20rpx; }
.nav-btn { color:#fff; font-size:52rpx; font-weight:300; padding:0 16rpx; line-height:1; }
.month-title { color:#fff; font-size:36rpx; font-weight:700; }

/* 日历 */
.calendar-card { background:#fff; border-radius:20rpx; padding:24rpx 16rpx;
  margin-bottom:20rpx; box-shadow:0 2rpx 16rpx rgba(0,0,0,.06); }
.week-header { display:grid; grid-template-columns:repeat(7,1fr); margin-bottom:8rpx; }
.week-label { text-align:center; font-size:24rpx; color:#bbb; padding:8rpx 0; }
.calendar-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4rpx; }
.day-cell { display:flex; flex-direction:column; align-items:center; justify-content:center;
  height:80rpx; border-radius:12rpx; position:relative; }
.day-num     { font-size:28rpx; color:#333; }
.day-num-out { font-size:28rpx; color:#ddd; }
.day-num-today { font-size:28rpx; color:#07c160; font-weight:700; }
.day-num-sel   { font-size:28rpx; color:#fff;     font-weight:700; }
.day-cell-sel  { background:#07c160; border-radius:50%; }
.dot      { width:8rpx; height:8rpx; border-radius:50%; background:#07c160;
  position:absolute; bottom:6rpx; }
.dot-sel  { width:8rpx; height:8rpx; border-radius:50%; background:#fff;
  position:absolute; bottom:6rpx; }

/* 卡片 */
.card { background:#fff; border-radius:20rpx; padding:28rpx 32rpx;
  margin-bottom:20rpx; box-shadow:0 2rpx 16rpx rgba(0,0,0,.06); }
.section-title { font-size:30rpx; font-weight:700; color:#333; margin-bottom:20rpx; }
.tip { text-align:center; color:#bbb; font-size:26rpx; padding:24rpx 0; }

/* 月度汇总 */
.total-row { display:flex; justify-content:space-between; align-items:center;
  padding-bottom:16rpx; border-bottom:2rpx solid #f0f0f0; margin-bottom:16rpx; }
.total-label { font-size:26rpx; color:#666; }
.total-amount { font-size:44rpx; font-weight:700; color:#07c160; }
.summary-row { display:flex; align-items:center; padding:14rpx 0; border-bottom:1rpx solid #f8f8f8; }
.summary-row:last-child { border-bottom:none; }
.summary-name { flex:1; font-size:28rpx; color:#333; }
.summary-val { font-size:30rpx; font-weight:600; color:#333; }

/* 通用 avatar */
.avatar { width:60rpx; height:60rpx; border-radius:50%; background:#e8f8ef;
  color:#07c160; font-size:24rpx; font-weight:700; display:flex;
  align-items:center; justify-content:center; margin-right:16rpx; flex-shrink:0; }
.avatar.sm { width:52rpx; height:52rpx; font-size:22rpx; }

/* 弹窗 */
.mask { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:100; }
.sheet { position:fixed; bottom:0; left:0; right:0; background:#f5f5f5;
  border-radius:32rpx 32rpx 0 0; padding:16rpx 24rpx 100rpx;
  z-index:101; max-height:90vh; overflow-y:auto; }
.sheet-bar { width:60rpx; height:8rpx; border-radius:4rpx; background:#ddd; margin:0 auto 16rpx; }
.sheet-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:20rpx; }
.sheet-date-tag { background:#07c160; color:#fff; border-radius:30rpx;
  padding:10rpx 28rpx; font-size:28rpx; font-weight:600; }
.sheet-close { color:#bbb; font-size:44rpx; padding:4rpx 12rpx; }

/* 内嵌卡片 */
.inner-card { background:#fff; border-radius:16rpx; padding:24rpx;
  margin-bottom:16rpx; border:1rpx solid #efefef; }
.result-card { background:#f8fdf9; }

/* Slider 块 */
.slider-block { padding-bottom:16rpx; margin-bottom:16rpx; border-bottom:1rpx solid #f0f0f0; }
.slider-block:last-child { border-bottom:none; margin-bottom:4rpx; }
.slider-row { display:flex; align-items:center; margin-bottom:10rpx; }
.slider-name { flex:1; font-size:28rpx; color:#333; font-weight:500; }
.slider-hours { font-size:26rpx; color:#07c160; font-weight:600; }

/* 按钮 */
.action-btn { border-radius:12rpx; padding:22rpx; text-align:center; font-size:28rpx; font-weight:600; margin-top:8rpx; }
.action-btn.ghost { color:#07c160; background:#f0faf4; border:1rpx solid #07c160; }
.action-btn.primary { background:#07c160; color:#fff; border-radius:50rpx; padding:28rpx;
  margin:8rpx 0 0; font-size:32rpx; box-shadow:0 4rpx 16rpx rgba(7,193,96,.3); }
.btn-dis { opacity:.6; }

/* 度数输入 */
.kwh-row { display:flex; align-items:center; background:#f8f8f8;
  border-radius:12rpx; padding:18rpx 20rpx; }
.kwh-input { flex:1; font-size:32rpx; color:#333; }
.kwh-unit { font-size:26rpx; color:#999; margin-left:8rpx; }
.cost-hint { font-size:26rpx; color:#666; padding:10rpx 4rpx 0; }
.cost-green { color:#07c160; font-weight:700; }

/* 结果 */
.result-row { display:flex; align-items:center; padding:14rpx 0; border-bottom:1rpx solid #eef8f2; }
.result-row:last-child { border-bottom:none; }
.result-info { flex:1; }
.result-name { display:block; font-size:28rpx; color:#333; font-weight:600; }
.result-sub  { display:block; font-size:22rpx; color:#aaa; margin-top:4rpx; }
.result-amt  { font-size:32rpx; font-weight:700; color:#07c160; }
.result-total-row { display:flex; justify-content:space-between; align-items:center;
  padding:18rpx 0 4rpx; border-top:2rpx solid #e8f8ef; margin-top:8rpx; }
.result-total-lbl { font-size:26rpx; color:#666; }
.result-total-val { font-size:40rpx; font-weight:700; color:#07c160; }
